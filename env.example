# A3: API Keys & Configuration
# Do not commit your real .env file!

# Local Inference (LM Studio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL_NAME=qwen3-vl-4b-4bit

# Cloud Inference (Gemini)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_NAME=gemini/gemini-1.5-flash-latest

# Vision Settings
MAX_VRAM_GB=6.0
VRAM_THRESHOLD_PERCENT=0.85 # Failover to Cloud if VRAM > 85%
PRIVACY_BLUR_ENABLED=true
